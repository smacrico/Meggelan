	measure 'Liver AST' =
			
			CALCULATE(
			    MAX(Fact_LiverMetrics[ast]),
			    FILTER(
			        ALL(Fact_LiverMetrics),
			        Fact_LiverMetrics[exam_date] = [Liver Anchor AST Data Date]
			    )
			)
		formatString: 0.00
		displayFolder: Liver - Latest
		lineageTag: e01358d2-6643-46f9-9142-828bc9e7133a

	measure 'Liver Previous AST' =
			
