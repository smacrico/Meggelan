	measure 'Liver AST/ALT Pattern Indicator' =
			
			VAR x = [Liver AST/ALT Ratio]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(x), BLANK(),
			    x < 0.5, "ALT-predominant",
			    x >= 0.7 && x <= 1.2, "Balanced",
			    x > 1.2 && x <= 2.0, "Borderline pattern",
			    x > 2.0, "AST-predominant / stronger concern",
			    "Borderline pattern"
			)
		displayFolder: Liver - KPI
		lineageTag: 685ae849-c689-44e2-acac-a06c303d8225

	measure 'Liver Direct Bilirubin % Indicator' =
			
			VAR x = [Liver Direct/Total Bilirubin %]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(x), BLANK(),
			    x < 20, "Low direct fraction",
			    x < 30, "Balanced",
			    x <= 40, "Borderline direct-predominant",
			    "Higher direct-predominant pattern"
			)
		displayFolder: Liver - KPI
		lineageTag: f6688d5a-a467-48ac-b1de-46b589d6627d

	measure 'Liver AST/ALT Score' =
			
			VAR x = [Liver AST/ALT Ratio]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(x), BLANK(),
			    x >= 0.7 && x <= 1.2, 1,
			    (x >= 0.5 && x < 0.7) || (x > 1.2 && x <= 2.0), 2,
			    3
			)
		formatString: 0
		displayFolder: Liver - KPI
		lineageTag: e6c29317-3439-4dc3-b7e8-1f04c5d3c8d7

	measure 'Liver Direct Bilirubin % Score' =
			
			VAR x = [Liver Direct/Total Bilirubin %]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(x), BLANK(),
			    x < 30, 1,
			    x <= 40, 2,
			    3
			)
		formatString: 0
		displayFolder: Liver - KPI
		lineageTag: 421d3d92-f740-40a2-a452-86fc26213fd4

	measure 'Liver Composite Risk Score' =
			
			AVERAGEX(
			    {
			        [Liver AST/ALT Score],
			        [Liver Direct Bilirubin % Score]
			    },
			    [Value]
			)
		formatString: 0.00
		displayFolder: Liver - KPI
		lineageTag: 0b7d8bad-8529-4ce8-8f3b-1083f988a95e

	measure 'Liver Composite KPI' =
			
			VAR x = [Liver Composite Risk Score]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(x), BLANK(),
			    x <= 1.4, "Favorable",
			    x <= 2.1, "Monitor",
