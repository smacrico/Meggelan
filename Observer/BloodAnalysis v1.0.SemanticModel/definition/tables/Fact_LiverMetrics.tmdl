table Fact_LiverMetrics
	lineageTag: a741aadb-c537-4a38-88ba-ec7d8611132a

	measure 'Liver Anchor Exam Date' =
			
			VAR SelectedDate = [Selected Anchor Calendar Date]
			RETURN
			IF(
			    NOT ISBLANK(SelectedDate),
			    MAXX(
			        FILTER(
			            ALLSELECTED(Fact_LiverMetrics),
			            Fact_LiverMetrics[exam_date] <= SelectedDate
			                && NOT ISBLANK(Fact_LiverMetrics[ast])
			        ),
			        Fact_LiverMetrics[exam_date]
			    ),
			    MAXX(
			        FILTER(
			            ALLSELECTED(Fact_LiverMetrics),
			            NOT ISBLANK(Fact_LiverMetrics[ast])
			        ),
			        Fact_LiverMetrics[exam_date]
			    )
			)
		formatString: yyyy-mm-dd
		displayFolder: Liver - Data Dates
		lineageTag: a21a77f8-9b84-44c4-b35e-6aa1da21e12d

	measure 'Liver Previous Exam Date' =
			
			MAXX(
			    FILTER(
			        ALLSELECTED(Fact_LiverMetrics),
			        Fact_LiverMetrics[exam_date] < [Liver Anchor Exam Date]
			            && NOT ISBLANK(Fact_LiverMetrics[ast])
			    ),
			    Fact_LiverMetrics[exam_date]
			)
		formatString: yyyy-mm-dd
		displayFolder: Liver - Data Dates
		lineageTag: 6bb55a4c-bbef-4bf2-85c6-96567aacaf49

	measure 'Liver Anchor AST Data Date' =
			
