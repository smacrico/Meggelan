	measure 'Liver AST Rolling 3' =
			
			AVERAGEX(
			    TOPN(
			        3,
			        FILTER(
			            ALLSELECTED(Fact_LiverMetrics),
			            Fact_LiverMetrics[exam_date] <= [Liver Anchor AST Data Date]
			                && NOT ISBLANK(Fact_LiverMetrics[ast])
			        ),
			        Fact_LiverMetrics[exam_date], DESC
			    ),
			    CALCULATE(MAX(Fact_LiverMetrics[ast]))
			)
		formatString: 0.00
		displayFolder: Liver - Rolling 3
		lineageTag: 2a74b27b-48ec-45c6-8129-f544c39bea93

	measure 'Liver AST Trend Direction' =
			
			VAR d = [Liver AST Delta]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(d), BLANK(),
			    d < 0, "Improving",
			    d > 0, "Worsening",
			    "Stable"
			)
		displayFolder: Liver - Trend
		lineageTag: 0090d574-8a07-4b54-8588-978db27bf25d

