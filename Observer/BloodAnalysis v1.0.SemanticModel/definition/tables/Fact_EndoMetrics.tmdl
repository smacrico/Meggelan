	measure 'Endo Glucose Trend Direction' =
			
			VAR d = [Endo Glucose Delta]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(d), BLANK(),
			    d < 0, "Improving",
			    d > 0, "Worsening",
			    "Stable"
			)
		displayFolder: Endo - Trend
		lineageTag: e7ae2a2e-7a97-4d94-8a4b-3ce84bdc722c

