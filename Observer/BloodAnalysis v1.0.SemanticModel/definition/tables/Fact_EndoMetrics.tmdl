	measure 'Endo Anchor Exam Date' =
			
			VAR SelectedDate = [Selected Anchor Calendar Date]
			RETURN
			IF(
			    NOT ISBLANK(SelectedDate),
			    MAXX(
			        FILTER(
			            ALLSELECTED(Fact_EndoMetrics),
			            Fact_EndoMetrics[exam_date] <= SelectedDate
			                && NOT ISBLANK(Fact_EndoMetrics[Endo Glucose])
			        ),
			        Fact_EndoMetrics[exam_date]
			    ),
			    MAXX(
			        FILTER(
			            ALLSELECTED(Fact_EndoMetrics),
			            NOT ISBLANK(Fact_EndoMetrics[Endo Glucose])
			        ),
			        Fact_EndoMetrics[exam_date]
			    )
			)
		formatString: yyyy-mm-dd
		displayFolder: Endo - Data Dates
		lineageTag: a5be9a0c-ac3d-4754-a634-2125afe722af

	measure 'Endo Previous Exam Date' =
			
			MAXX(
