table Fact_LipidMetrics
	lineageTag: c519e5ac-8cc0-49cf-81fd-b57895b3302d

	measure 'Lipid Total Cholesterol' =
			
			CALCULATE(
			    MAX(Fact_LipidMetrics[total_cholesterol]),
			    FILTER(
			        ALL(Fact_LipidMetrics),
			        Fact_LipidMetrics[exam_date] = [Lipid Anchor Total Cholesterol Data Date]
			    )
			)
		formatString: 0.00
		displayFolder: Lipid - Latest
		lineageTag: e4ce3e4b-773f-48c3-95f4-731b60371a2b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Lipid Previous Total Cholesterol' =
			
			CALCULATE(
			    MAX(Fact_LipidMetrics[total_cholesterol]),
			    FILTER(
			        ALL(Fact_LipidMetrics),
			        Fact_LipidMetrics[exam_date] = [Lipid Previous Total Cholesterol Data Date]
			    )
			)
		formatString: 0.00
		displayFolder: Lipid - Previous
		lineageTag: 24b6fd96-4b54-4bf5-9e64-2adfff1e2e39

	measure 'Lipid Total Cholesterol Delta' = [Lipid Total Cholesterol] - [Lipid Previous Total Cholesterol]
		formatString: 0.00
		displayFolder: Lipid - Delta
		lineageTag: 75f85642-564c-4bc9-8c33-e56718f480a9

	measure 'Lipid Total Cholesterol Delta %' = DIVIDE([Lipid Total Cholesterol Delta], [Lipid Previous Total Cholesterol])
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Lipid - Delta %
		lineageTag: 73055aed-ef88-4f4a-b725-e982f9ff5fc8

	measure 'Lipid Total Cholesterol Rolling 3' =
			
			AVERAGEX(
			    TOPN(
			        3,
			        FILTER(
			            ALLSELECTED(Fact_LipidMetrics),
			            Fact_LipidMetrics[exam_date] <= [Lipid Anchor Total Cholesterol Data Date]
			                && NOT ISBLANK(Fact_LipidMetrics[total_cholesterol])
			        ),
			        Fact_LipidMetrics[exam_date], DESC
			    ),
			    CALCULATE(MAX(Fact_LipidMetrics[total_cholesterol]))
			)
		formatString: 0.00
		displayFolder: Lipid - Rolling 3
		lineageTag: 94594593-2383-48cf-8cdc-ef7f0208e158

