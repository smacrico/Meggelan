	measure 'Lipid AIP Score' =
			
			VAR x = [Lipid Latest AIP]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(x), BLANK(),
			    x < 0.11, 1,
			    x < 0.21, 2,
			    3
			)
		formatString: 0
