	measure 'Lipid Total Cholesterol Trend Direction' =
			
			VAR d = [Lipid Total Cholesterol Delta]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(d), BLANK(),
			    d < 0, "Improving",
			    d > 0, "Worsening",
			    "Stable"
			)
		displayFolder: Lipid - Trend
		lineageTag: 5c85ffc4-2753-401e-ad7e-105f0e51c9fa

