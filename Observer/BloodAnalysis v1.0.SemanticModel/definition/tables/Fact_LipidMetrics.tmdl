	/// Use with trend line to highlight the selected/latest anchor exam.
	measure 'Lipid Total Cholesterol Anchor Marker' =
			
			VAR CurrentAxisDate = MAX(Fact_LipidMetrics[exam_date])
			VAR AnchorDate = [Lipid Anchor Total Cholesterol Data Date]
			RETURN
			IF(
			    NOT ISBLANK(AnchorDate) && CurrentAxisDate = AnchorDate,
			    MAX(Fact_LipidMetrics[total_cholesterol]),
			    BLANK()
			)
		formatString: 0.00
		displayFolder: Lipid - Anchor Markers
		lineageTag: eead3168-8e4e-4379-bf10-bd427d6e35b8

