	measure 'Lipid TG/HDL Score' =
			
			VAR x = [Lipid Latest TG/HDL]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(x), BLANK(),
			    x < 2, 1,
			    x < 3, 2,
			    x < 4, 3,
			    4
			)
		formatString: 0
		displayFolder: Lipid - KPI
		lineageTag: 1723da84-9383-4668-b078-ec6efd709883

	measure 'Lipid Remnant Score' =
			
			VAR x = [Lipid Latest Remnant]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(x), BLANK(),
			    x < 20, 1,
			    x <= 30, 2,
			    3
			)
		formatString: 0
		displayFolder: Lipid - KPI
		lineageTag: ab740bd6-7505-44ad-aa39-1049e6b7e0f0

	measure 'Lipid TC/HDL Score' =
			
			VAR x = [Lipid Latest TC/HDL]
