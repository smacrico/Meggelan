	measure 'Lipid Composite Risk Score' =
			
			AVERAGEX(
			    {
			        [Lipid AIP Score],
			        [Lipid TG/HDL Score],
			        [Lipid Remnant Score],
			        [Lipid TC/HDL Score],
			        [Lipid LDL/HDL Score],
