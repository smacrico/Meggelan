        ],
        "partitions": [
          {
            "name": "Dim_Date",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": [
                "ADDCOLUMNS(",
                "    CALENDAR(",
                "        DATE(2017,1,1),",
                "        DATE(2035,12,31)",
                "    ),",
                "    \"Year\", YEAR([Date]),",
                "    \"MonthNo\", MONTH([Date]),",
                "    \"Month\", FORMAT([Date], \"MMM\"),",
                "    \"YearMonth\", FORMAT([Date], \"YYYY-MM\"),",
                "    \"Quarter\", \"Q\" & FORMAT([Date], \"Q\")",
                ")"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Latest Selected Date",
            "expression": "MAX(Dim_Date[Date])",
            "formatString": "General Date",
            "displayFolder": "_Common",
            "lineageTag": "835125cc-8765-4e29-89f3-509c1fcb204a"
          },
          {
            "name": "Previous Selected Date",
            "expression": [
              "",
              "CALCULATE(",
              "    MAX(Dim_Date[Date]),",
              "    FILTER(",
              "        ALLSELECTED(Dim_Date[Date]),",
              "        Dim_Date[Date] < [Latest Selected Date]",
              "    )",
              ")"
            ],
            "formatString": "General Date",
            "displayFolder": "_Common",
            "lineageTag": "1d76d620-cc92-4e72-928e-fbe36ae8926e"
          },
          {
            "name": "Test Count",
            "expression": "COUNTROWS(VALUES(Dim_Date[Date]))",
            "formatString": "0",
            "displayFolder": "_Common",
            "lineageTag": "aeb7b888-31a7-45ba-a9be-8f8a4ea41aa8"
          },
          {
            "name": "Days Between Latest And Previous Test",
            "expression": "DATEDIFF([Previous Selected Date], [Latest Selected Date], DAY)",
            "formatString": "0",
            "displayFolder": "_Common",
            "lineageTag": "ea67d2cf-106e-43f3-8f22-065243c60ea1"
          },
          {
            "name": "Dim_Profile",
            "expression": [
              "",
              "DATATABLE(",
              "    \"ProfileKey\", STRING,",
              "    \"ProfileName\", STRING,",
              "    {",
              "        {\"LIPID\", \"Lipidemic\"},",
              "        {\"ENDO\", \"Endocrinology\"}",
              "    }",
              ")"
            ],
            "lineageTag": "3816c414-da3e-4c1f-92d8-eef0923a4130"
          },
          {
            "name": "Latest Selected Calendar Date",
            "expression": "MAX(Dim_Date[Date])",
            "formatString": "yyyy-mm-dd",
            "displayFolder": "_Common",
            "lineageTag": "c17cc6e1-daa5-4ee6-be56-8467fc84375d"
          },
          {
            "name": "Previous Selected Calendar Date",
            "expression": [
              "",
              "CALCULATE(",
              "    MAX(Dim_Date[Date]),",
              "    FILTER(",
              "        ALLSELECTED(Dim_Date[Date]),",
              "        Dim_Date[Date] < [Latest Selected Calendar Date]",
              "    )",
              ")"
            ],
            "formatString": "yyyy-mm-dd",
            "displayFolder": "_Common",
            "lineageTag": "5e2ae2a4-7af9-497a-bcc6-db3fae32657b"
          }
        ],
        "annotations": [
          {
            "name": "PBI_Id",
            "value": "a5b26acb453f4a588699dea5e2a2907c"
          }
        ]
