            "lineageTag": "0c23f692-b5de-4790-91fc-7ff778998e13"
          },
          {
            "name": "Lipid LDL/HDL Score",
            "expression": [
              "",
              "VAR x = [Lipid Latest LDL/HDL]",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    ISBLANK(x), BLANK(),",
              "    x < 2, 1,",
              "    x < 3, 2,",
              "    3",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Lipid - KPI",
            "lineageTag": "8ff34f63-b03f-4f64-a28f-752a388eb320"
          },
          {
            "name": "Lipid Non-HDL Score",
            "expression": [
              "",
              "VAR x = [Lipid Latest Non-HDL]",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    ISBLANK(x), BLANK(),",
              "    x < 130, 1,",
              "    x < 160, 2,",
              "    x < 190, 3,",
              "    4",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Lipid - KPI",
            "lineageTag": "29c16178-50fd-4d5d-a735-1b360dd4e9e5"
          },
          {
            "name": "Lipid AIP Indicator",
            "expression": [
              "",
              "SWITCH(",
              "    [Lipid AIP Score],",
              "    1, \"Low risk\",",
              "    2, \"Intermediate risk\",",
              "    3, \"High risk\",",
              "    BLANK()",
              ")"
            ],
            "displayFolder": "Lipid - KPI",
            "lineageTag": "1b135e4a-239f-44b6-9f70-679ad13b52f8"
          },
          {
            "name": "Lipid TG/HDL Indicator",
            "expression": [
              "",
              "SWITCH(",
              "    [Lipid TG/HDL Score],",
              "    1, \"Favorable\",",
              "    2, \"Borderline\",",
              "    3, \"Higher risk\",",
              "    4, \"Marked metabolic-risk signal\",",
              "    BLANK()",
              ")"
            ],
            "displayFolder": "Lipid - KPI",
            "lineageTag": "2d9348e1-1595-408e-9e91-04db3efb1022"
          },
          {
            "name": "Lipid Remnant Indicator",
            "expression": [
              "",
              "SWITCH(",
              "    [Lipid Remnant Score],",
              "    1, \"Favorable\",",
              "    2, \"Borderline\",",
              "    3, \"Higher residual risk\",",
              "    BLANK()",
              ")"
            ],
            "displayFolder": "Lipid - KPI",
            "lineageTag": "3b89b128-58ff-4a71-8ab6-855ab50e2a4e"
          },
          {
            "name": "Lipid TC/HDL Indicator",
            "expression": [
              "",
              "SWITCH(",
              "    [Lipid TC/HDL Score],",
              "    1, \"Favorable\",",
              "    2, \"Borderline\",",
              "    3, \"Higher risk\",",
              "    BLANK()",
              ")"
            ],
            "displayFolder": "Lipid - KPI",
            "lineageTag": "9289f748-9a5b-49d6-89c7-537828c787eb"
          },
          {
            "name": "Lipid LDL/HDL Indicator",
            "expression": [
              "",
              "SWITCH(",
              "    [Lipid LDL/HDL Score],",
              "    1, \"Favorable\",",
              "    2, \"Borderline\",",
              "    3, \"Less favorable\",",
              "    BLANK()",
              ")"
            ],
            "displayFolder": "Lipid - KPI",
            "lineageTag": "07c4283d-9a50-4cc7-9ac7-171d1c1e5234"
          },
          {
            "name": "Lipid Non-HDL Indicator",
            "expression": [
              "",
              "SWITCH(",
              "    [Lipid Non-HDL Score],",
              "    1, \"Optimal / near-optimal\",",
              "    2, \"Borderline high\",",
              "    3, \"High\",",
              "    4, \"Very high\",",
              "    BLANK()",
              ")"
            ],
            "displayFolder": "Lipid - KPI",
            "lineageTag": "60bae0c0-5ad4-4579-abaf-866327222db3"
          },
          {
            "name": "Lipid Composite Risk Score",
            "expression": [
              "",
              "AVERAGEX(",
              "    {",
              "        [Lipid AIP Score],",
              "        [Lipid TG/HDL Score],",
              "        [Lipid Remnant Score],",
              "        [Lipid TC/HDL Score],",
              "        [Lipid LDL/HDL Score],",
              "        [Lipid Non-HDL Score]",
              "    },",
              "    [Value]",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Lipid - KPI",
            "lineageTag": "c07473a8-a0ef-4f2c-840f-e5ae5b655b85"
          },
          {
            "name": "Lipid Composite KPI",
            "expression": [
              "",
              "VAR x = [Lipid Composite Risk Score]",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    ISBLANK(x), BLANK(),",
              "    x <= 1.5, \"Favorable\",",
              "    x <= 2.3, \"Monitor\",",
              "    x <= 3.2, \"Elevated risk pattern\",",
              "    \"High concern\"",
              ")"
            ],
            "displayFolder": "Lipid - KPI",
            "lineageTag": "6e6c2383-9acf-4e7a-aa90-d465b2d857af"
          },
          {
            "name": "Lipid Composite Color Hex",
            "expression": [
              "",
              "VAR x = [Lipid Composite Risk Score]",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    ISBLANK(x), BLANK(),",
              "    x <= 1.5, \"#2E7D32\",",
              "    x <= 2.3, \"#F9A825\",",
              "    x <= 3.2, \"#EF6C00\",",
              "    \"#C62828\"",
              ")"
            ],
            "displayFolder": "Lipid - KPI",
            "lineageTag": "6419d76c-6d64-4c31-a2de-45f71de80201"
          },
          {
            "name": "Lipid AIP Stability KPI",
            "expression": "ABS([Lipid Latest AIP] - [Lipid AIP Rolling 3])",
