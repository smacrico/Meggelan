          {
            "name": "Lipid Days Since Previous Test",
            "expression": [
              "",
              "DATEDIFF([Previous Selected Date], [Latest Selected Date], DAY)"
            ],
            "displayFolder": "Lipid - Previous",
            "lineageTag": "9d74d26a-50a8-4cac-aa96-c93413f27420",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Lipid Latest Data Date",
            "expression": [
              "",
              "MAXX(",
              "    FILTER(",
              "        ALLSELECTED(Fact_LipidMetrics),",
              "        NOT ISBLANK(Fact_LipidMetrics[total_cholesterol])",
              "    ),",
              "    Fact_LipidMetrics[exam_date]",
              ")"
            ],
            "displayFolder": "Lipid - Latest",
            "lineageTag": "55ed9e2b-2375-4fdb-83cf-2be75e30f442",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Lipid Previous Data Date",
            "expression": [
              "",
              "MAXX(",
              "    FILTER(",
              "        ALLSELECTED(Fact_LipidMetrics),",
              "        Fact_LipidMetrics[exam_date] < [Lipid Latest Data Date]",
              "            && NOT ISBLANK(Fact_LipidMetrics[total_cholesterol])",
              "    ),",
              "    Fact_LipidMetrics[exam_date]",
              ")"
            ],
            "displayFolder": "Lipid - Previous",
            "lineageTag": "f28b0f7e-2b09-4079-85a6-13e9de844752",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
