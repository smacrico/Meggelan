        "partitions": [
          {
            "name": "Fact_LipidMetrics",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Odbc.DataSource(\"dsn=bllod_raw\", [HierarchicalNavigation=true]),",
                "    lipid_metrics_Table = Source{[Name=\"lipid_metrics\",Kind=\"Table\"]}[Data],",
                "    #\"Changed Type with Locale\" = Table.TransformColumnTypes(lipid_metrics_Table, {{\"exam_date\", type date}}, \"el-GR\")",
                "in",
                "    #\"Changed Type with Locale\""
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Lipid Latest Total Cholesterol",
            "expression": [
              "",
              "CALCULATE(",
              "    MAX(Fact_LipidMetrics[total_cholesterol]),",
              "    FILTER(",
              "        ALL(Fact_LipidMetrics),",
              "        Fact_LipidMetrics[exam_date] = [Lipid Latest Total Cholesterol Data Date]",
              "    )",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Lipid - Latest",
            "lineageTag": "e4ce3e4b-773f-48c3-95f4-731b60371a2b",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Lipid Previous Total Cholesterol",
            "expression": [
              "",
              "CALCULATE(",
              "    MAX(Fact_LipidMetrics[total_cholesterol]),",
              "    FILTER(",
              "        ALL(Fact_LipidMetrics),",
              "        Fact_LipidMetrics[exam_date] = [Lipid Previous Total Cholesterol Data Date]",
              "    )",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Lipid - Previous",
            "lineageTag": "24b6fd96-4b54-4bf5-9e64-2adfff1e2e39"
          },
          {
            "name": "Lipid Total Cholesterol Delta",
            "expression": "[Lipid Latest Total Cholesterol] - [Lipid Previous Total Cholesterol]",
            "formatString": "0.00",
            "displayFolder": "Lipid - Delta",
            "lineageTag": "75f85642-564c-4bc9-8c33-e56718f480a9"
          },
          {
            "name": "Lipid Total Cholesterol Delta %",
            "expression": "DIVIDE([Lipid Total Cholesterol Delta], [Lipid Previous Total Cholesterol])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Lipid - Delta %",
            "lineageTag": "73055aed-ef88-4f4a-b725-e982f9ff5fc8"
          },
          {
            "name": "Lipid Total Cholesterol Rolling 3",
            "expression": [
              "",
              "AVERAGEX(",
              "    TOPN(",
              "        3,",
              "        FILTER(",
              "            ALLSELECTED(Fact_LipidMetrics),",
              "            NOT ISBLANK(Fact_LipidMetrics[total_cholesterol])",
              "        ),",
              "        Fact_LipidMetrics[exam_date], DESC",
              "    ),",
              "    CALCULATE(MAX(Fact_LipidMetrics[total_cholesterol]))",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Lipid - Rolling 3",
            "lineageTag": "94594593-2383-48cf-8cdc-ef7f0208e158"
          },
          {
            "name": "Lipid Latest HDL",
            "expression": [
              "",
              "CALCULATE(",
              "    MAX(Fact_LipidMetrics[hdl]),",
              "    FILTER(",
              "        ALL(Fact_LipidMetrics),",
              "        Fact_LipidMetrics[exam_date] = [Lipid Latest HDL Data Date]",
              "    )",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Lipid - Latest",
            "lineageTag": "4b94bd79-a117-4f3a-b15c-b64fb2493c98"
          },
          {
            "name": "Lipid Previous HDL",
            "expression": [
              "",
              "CALCULATE(",
              "    MAX(Fact_LipidMetrics[hdl]),",
              "    FILTER(",
              "        ALL(Fact_LipidMetrics),",
              "        Fact_LipidMetrics[exam_date] = [Lipid Previous HDL Data Date]",
              "    )",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Lipid - Previous",
            "lineageTag": "10ce3a65-1940-4183-bc4a-e748ab3f3938"
          },
          {
            "name": "Lipid HDL Delta",
            "expression": "[Lipid Latest HDL] - [Lipid Previous HDL]",
            "formatString": "0.00",
            "displayFolder": "Lipid - Delta",
            "lineageTag": "86d73463-27ea-461d-81d5-99a4c3baff82"
          },
          {
            "name": "Lipid HDL Delta %",
            "expression": "DIVIDE([Lipid HDL Delta], [Lipid Previous HDL])",
