        "partitions": [
          {
            "name": "Fact_EndoMetrics",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Odbc.DataSource(\"dsn=bllod_raw\", [HierarchicalNavigation=true]),",
                "    endo_metrics_Table = Source{[Name=\"endo_metrics\",Kind=\"Table\"]}[Data],",
                "    #\"Changed Type\" = Table.TransformColumnTypes(endo_metrics_Table,{{\"exam_date\", type date}, {\"created_at\", type datetime}, {\"updated_at\", type datetime}})",
                "in",
                "    #\"Changed Type\""
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Endo Latest Glucose",
            "expression": [
              "",
              "CALCULATE(",
              "    MAX(Fact_EndoMetrics[glucose_for_calc]),",
              "    FILTER(",
              "        ALL(Fact_EndoMetrics),",
              "        Fact_EndoMetrics[exam_date] = [Endo Latest Glucose Data Date]",
              "    )",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Endo - Latest",
            "lineageTag": "2def5c6e-de5a-435d-952b-7170ecb1e766"
          },
          {
            "name": "Endo Previous Glucose",
            "expression": [
              "",
              "CALCULATE(",
              "    MAX(Fact_EndoMetrics[glucose_for_calc]),",
              "    FILTER(",
              "        ALL(Fact_EndoMetrics),",
              "        Fact_EndoMetrics[exam_date] = [Endo Previous Glucose Data Date]",
              "    )",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Endo - Previous",
            "lineageTag": "9f64f5c5-aa49-485a-9223-5f33c91e8129"
          },
          {
            "name": "Endo Glucose Delta",
            "expression": "[Endo Latest Glucose] - [Endo Previous Glucose]",
            "formatString": "0.00",
            "displayFolder": "Endo - Delta",
            "lineageTag": "4f38a9ac-68fe-41f1-8a7c-f3c76cf424a4"
          },
          {
            "name": "Endo Glucose Delta %",
            "expression": "DIVIDE([Endo Glucose Delta], [Endo Previous Glucose])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Endo - Delta %",
            "lineageTag": "bdbdc163-9ac6-4776-8f1c-799ad78446e7"
          },
          {
            "name": "Endo Glucose Rolling 3",
            "expression": [
              "",
              "AVERAGEX(",
              "    TOPN(",
              "        3,",
              "        FILTER(",
              "            ALLSELECTED(Fact_EndoMetrics),",
              "            NOT ISBLANK(Fact_EndoMetrics[glucose_for_calc])",
              "        ),",
              "        Fact_EndoMetrics[exam_date], DESC",
              "    ),",
              "    CALCULATE(MAX(Fact_EndoMetrics[glucose_for_calc]))",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Endo - Rolling 3",
            "lineageTag": "45401005-af74-4b24-9bb6-fae9221367d3"
          },
          {
            "name": "Endo Latest Fasting Insulin",
            "expression": [
              "",
              "CALCULATE(",
              "    MAX(Fact_EndoMetrics[fasting_insulin]),",
              "    FILTER(",
              "        ALL(Fact_EndoMetrics),",
              "        Fact_EndoMetrics[exam_date] = [Endo Latest Fasting Insulin Data Date]",
              "    )",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Endo - Latest",
            "lineageTag": "1be40d9c-8625-43ac-a755-2a5960b2d7ff"
          },
          {
            "name": "Endo Previous Fasting Insulin",
            "expression": [
              "",
              "CALCULATE(",
              "    MAX(Fact_EndoMetrics[fasting_insulin]),",
              "    FILTER(",
              "        ALL(Fact_EndoMetrics),",
              "        Fact_EndoMetrics[exam_date] = [Endo Previous Fasting Insulin Data Date]",
