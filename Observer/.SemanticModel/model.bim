              "    2, \"Borderline insulin resistance\",",
              "    3, \"Insulin resistance signal\",",
              "    BLANK()",
              ")"
            ],
            "displayFolder": "Endo - KPI",
            "lineageTag": "fbe2e351-d14d-4513-aff0-285f90bbb314"
          },
          {
            "name": "Endo QUICKI Indicator",
            "expression": [
              "",
              "SWITCH(",
              "    [Endo QUICKI Score],",
              "    1, \"Better insulin sensitivity\",",
              "    2, \"Borderline\",",
              "    3, \"Lower insulin sensitivity\",",
              "    BLANK()",
              ")"
            ],
            "displayFolder": "Endo - KPI",
            "lineageTag": "6025cfbc-730f-4056-865e-5309097c0006"
          },
          {
            "name": "Endo Vitamin D Indicator",
            "expression": [
              "",
              "VAR x = [Endo Latest Vitamin D]",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    ISBLANK(x), BLANK(),",
              "    x < 20, \"Deficient\",",
              "    x < 30, \"Insufficient\",",
              "    x <= 50, \"Sufficient\",",
              "    x <= 100, \"High / upper range\",",
              "    \"Potential excess\"",
              ")"
            ],
            "displayFolder": "Endo - KPI",
            "lineageTag": "758f9008-ee13-42ba-80e2-5df58a271ffa"
          },
          {
            "name": "Endo HbA1c Indicator",
            "expression": [
              "",
              "SWITCH(",
              "    [Endo HbA1c Score],",
              "    1, \"Favorable\",",
              "    2, \"Prediabetes range\",",
              "    3, \"Diabetes range\",",
              "    BLANK()",
              ")"
            ],
            "displayFolder": "Endo - KPI",
            "lineageTag": "02aa1c78-db5c-4718-8fc8-0dca59a72535"
          },
          {
            "name": "Endo Glucose Indicator",
            "expression": [
              "",
              "SWITCH(",
              "    [Endo Glucose Score],",
              "    1, \"Favorable\",",
              "    2, \"Impaired fasting range\",",
              "    3, \"High fasting glucose range\",",
              "    BLANK()",
              ")"
            ],
            "displayFolder": "Endo - KPI",
            "lineageTag": "50c71481-ad84-4d93-9bcf-066ab4acda91"
          },
          {
            "name": "Endo Composite Risk Score",
            "expression": [
              "",
              "AVERAGEX(",
              "    {",
              "        [Endo HOMA-IR Score],",
              "        [Endo QUICKI Score],",
              "        [Endo Vitamin D Score],",
              "        [Endo HbA1c Score],",
              "        [Endo Glucose Score]",
              "    },",
              "    [Value]",
              ")"
            ],
            "formatString": "0.00",
            "displayFolder": "Endo - KPI",
            "lineageTag": "92ae1fc2-1ca1-455f-a0d9-9a6b7ee20342"
          },
          {
            "name": "Endo Composite KPI",
            "expression": [
              "",
              "VAR x = [Endo Composite Risk Score]",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    ISBLANK(x), BLANK(),",
              "    x <= 1.4, \"Favorable\",",
              "    x <= 2.1, \"Monitor\",",
              "    x <= 2.8, \"Elevated metabolic/endocrine concern\",",
              "    \"High concern\"",
              ")"
            ],
            "displayFolder": "Endo - KPI",
            "lineageTag": "3e83e0ce-2218-4259-91fd-5731f95b33de"
          },
          {
            "name": "Endo Composite Color Hex",
            "expression": [
              "",
              "VAR x = [Endo Composite Risk Score]",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    ISBLANK(x), BLANK(),",
              "    x <= 1.4, \"#2E7D32\",",
              "    x <= 2.1, \"#F9A825\",",
              "    x <= 2.8, \"#EF6C00\",",
              "    \"#C62828\"",
              ")"
            ],
            "displayFolder": "Endo - KPI",
            "lineageTag": "fa0fe00b-e001-4251-88fc-fe6f3da7b41b"
          },
