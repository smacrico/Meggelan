{
  "name": "HRV Platform Theme",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 16
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 24
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "background": [
          {
            "show": false
          }
        ]
      }
    }
  }
}