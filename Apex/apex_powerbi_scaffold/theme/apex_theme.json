{
  "name": "Apex Running Theme",
  "dataColors": [
    "#1F77B4",
    "#2CA02C",
    "#FF7F0E",
    "#9467BD",
    "#D62728",
    "#17BECF",
    "#8C564B",
    "#BCBD22"
  ],
  "background": "#FFFFFF",
  "foreground": "#1F1F1F",
  "tableAccent": "#1F77B4",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold",
            "color": { "solid": { "color": "#1F1F1F" } }
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#333333" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "background": [
          {
            "show": false,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#555555" } },
            "fontSize": 11
          }
        ],
        "calloutValue": [
          {
            "color": { "solid": { "color": "#111111" } },
            "fontSize": 28
          }
        ]
      }
    }
  }
}
